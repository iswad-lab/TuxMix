# Maintainer: iswad-lab <iswad@lab.dev>

# tinyface — TotalMix replacement for RME audio interfaces on Linux
#
# Building from source requires Rust (cargo) and ALSA development headers.
#
# When a new version is tagged on GitHub, update pkgver and the source
# tarball checksum below.

pkgname=tinyface
pkgver=0.1.0
pkgrel=1
pkgdesc="TotalMix replacement for RME audio interfaces on Linux"
arch=('x86_64')
url="https://github.com/iswad-lab/Tinyface"
license=('GPL3')
depends=(
    'alsa-lib'
    'libgl'
)
makedepends=(
    'cargo'
)
source=("${url}/archive/v${pkgver}/${pkgname}-${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cd "${srcdir}/${pkgname}-${pkgver}"
    cargo build --release --workspace
}

package() {
    cd "${srcdir}/${pkgname}-${pkgver}"

    install -Dm755 "target/release/tinyface-gui" \
        "${pkgdir}/usr/bin/tinyface"
    install -Dm755 "target/release/tinyface-tui" \
        "${pkgdir}/usr/bin/tinyface-tui"

    install -Dm644 "README.md" \
        "${pkgdir}/usr/share/doc/tinyface/README.md"
}
